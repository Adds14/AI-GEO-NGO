# Google Earth Engine
GEE_PROJECT_ID=your-gee-project-id
GEE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=path/to/service-account-key.json

# Application
APP_NAME=AI-GEO-NGO
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True

# Database
DATABASE_URL=sqlite:///./data/app.db

# Paths
DATA_DIR=./data
MODEL_DIR=./models
REPORT_DIR=./data/reports
